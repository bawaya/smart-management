{
  "name": "smart-management-tests",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:api": "vitest run api/",
    "test:security": "vitest run security/",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "setup": "tsx global-setup.ts",
    "teardown": "tsx global-teardown.ts",
    "check": "tsc --noEmit",
    "users:seed": "tsx scripts/seed-test-users.ts",
    "users:verify": "tsx scripts/verify-logins.ts",
    "users:reset": "tsx scripts/reset-test-users.ts",
    "probe:rbac": "tsx scripts/probe-rbac.ts",
    "test:cleanup": "tsx scripts/cleanup-test-data.ts",
    "obs:seed": "tsx scripts/seed-observability-user.ts",
    "obs:cleanup": "tsx scripts/cleanup-observability-user.ts",
    "test:observability": "tsx scripts/run-observability.ts",
    "monitor": "bash scripts/monitor.sh",
    "monitor:live": "bash scripts/monitor.sh live",
    "monitor:attackers": "bash scripts/monitor.sh attackers",
    "monitor:watch": "bash scripts/monitor.sh watch"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "zod": "^3.23.0"
  }
}
