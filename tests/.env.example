BASE_URL=https://smart-management.pages.dev
TEST_TENANT_PREFIX=test_ci_

# Test user credentials. Passwords only are secrets in CI; usernames are
# deterministic (seeded by scripts/seed-test-users.ts) except OWNER which
# points at a real user on prod.
OWNER_USERNAME=admin
OWNER_PASSWORD=
MANAGER_USERNAME=test_manager
MANAGER_PASSWORD=
ACCOUNTANT_USERNAME=test_accountant
ACCOUNTANT_PASSWORD=
OPERATOR_USERNAME=test_operator
OPERATOR_PASSWORD=
VIEWER_USERNAME=test_viewer
VIEWER_PASSWORD=

# Cloudflare D1 access — required for the global teardown to delete TEST_ rows
# via `wrangler d1 execute --remote`. Not required for local-only dev runs
# where you're OK leaving TEST_ rows behind.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
